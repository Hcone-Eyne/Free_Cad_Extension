
import Path
import FreeCAD as App
import Part

doc = App.newDocument("CuboidDocument")

length = 50.0
width = 20.0
height = 10.0

cuboid = Part.makeBox(length, width, height)
shape_obj = doc.addObject("Part::Feature", "Cuboid")
shape_obj.Shape = cuboid

doc.recompute()

output_path = 'voice_input/ai_generated_scripts'
import os
if not os.path.exists(output_path):
    os.makedirs(output_path)

shape_obj.exportStep(os.path.join(output_path, "cuboid.step"))
